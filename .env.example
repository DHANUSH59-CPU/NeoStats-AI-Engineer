# ===========================================================================
# Credit Risk Intelligence Platform — environment variables
# Copy this file to `.env` and fill in your values:  cp .env.example .env
# ===========================================================================

# --- LLM (Talk-to-Data chatbot) -------------------------------------------
# Google Gemini API key. Get a free key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# Gemini model for NL -> SQL. `gemini-flash-latest` always points at the current
# fast Flash model. NOTE: the free tier is rate-limited (~5 requests/min, ~20/day
# per model). The chatbot automatically falls back to a built-in offline SQL
# generator when the limit is hit, so it keeps working regardless.
GEMINI_MODEL=gemini-flash-latest

# --- Paths (defaults work for local + Docker; override only if needed) -----
DATA_DIR=data/home-credit-default-risk
MODEL_PATH=models/model.pkl
DB_PATH=models/credit.db

# --- API server ------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Talk-to-data safety ---------------------------------------------------
# Max rows any generated SQL query may return.
SQL_ROW_LIMIT=100
